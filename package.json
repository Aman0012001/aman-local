{
  "name": "hyperlocal-discovery-platform",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:backend": "npm run start:dev --workspace=@business-saas/api",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:backend\"",
    "build": "npm run build --workspace=@business-saas/api && npm run build --workspace=@apps/web",
    "lint": "npm run lint --workspaces --if-present",
    "start": "npm run start:prod --workspace=@business-saas/api",
    "start:prod": "npm run start:prod --workspace=@business-saas/api",
    "debug:dist": "ls -R backend/dist"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "concurrently": "^9.2.1",
    "rxjs": "7.8.1",
    "tailwindcss": "^3.4.1",
    "turbo": "latest"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rxjs": "7.8.1"
  }
}
